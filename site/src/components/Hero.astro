---

<section class="hero">
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="logo">
        <span class="logo-icon">🥢</span>
        <span class="logo-text">Chops</span>
      </a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="https://github.com/Shpigford/chops" target="_blank" rel="noopener">GitHub</a>
        <a href="https://github.com/Shpigford/chops/releases/latest" class="btn btn-sm" target="_blank" rel="noopener">Download</a>
      </div>
    </div>
  </nav>

  <div class="hero-content">
    <div class="hero-text fade-up">
      <div class="badge fade-up">
        <span class="badge-dot"></span>
        Free & open source for macOS
      </div>
      <h1 class="fade-up fade-up-delay-1">
        Your AI agent skills,<br />
        <span class="gradient-text">finally organized.</span>
      </h1>
      <p class="hero-subtitle fade-up fade-up-delay-2">
        One app to discover, organize, tag, and edit coding agent skills across Claude Code, Cursor, Codex, Windsurf, Copilot, Aider, and Amp. Stop digging through dotfiles.
      </p>
      <div class="hero-actions fade-up fade-up-delay-3">
        <a href="https://github.com/Shpigford/chops/releases/latest" class="btn btn-primary" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download for macOS
        </a>
        <a href="https://github.com/Shpigford/chops" class="btn btn-secondary" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>
      <div class="hero-tools fade-up fade-up-delay-4">
        <span class="tools-label">Works with</span>
        <div class="tools-list">
          <span class="tool-tag">Claude Code</span>
          <span class="tool-tag">Cursor</span>
          <span class="tool-tag">Codex</span>
          <span class="tool-tag">Windsurf</span>
          <span class="tool-tag">Copilot</span>
          <span class="tool-tag">Aider</span>
          <span class="tool-tag">Amp</span>
        </div>
      </div>
    </div>

    <div class="hero-screenshot fade-up fade-up-delay-3">
      <div class="screenshot-window">
        <div class="window-chrome">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
        </div>
        <div class="screenshot-body">
          <div class="mock-sidebar">
            <div class="mock-sidebar-header"></div>
            <div class="mock-item active"></div>
            <div class="mock-item"></div>
            <div class="mock-item"></div>
            <div class="mock-item"></div>
            <div class="mock-item"></div>
            <div class="mock-section-label"></div>
            <div class="mock-item"></div>
            <div class="mock-item"></div>
            <div class="mock-item"></div>
          </div>
          <div class="mock-main">
            <div class="mock-toolbar">
              <div class="mock-search"></div>
              <div class="mock-actions">
                <div class="mock-action-btn"></div>
                <div class="mock-action-btn"></div>
              </div>
            </div>
            <div class="mock-content">
              <div class="mock-card">
                <div class="mock-card-title"></div>
                <div class="mock-card-body">
                  <div class="mock-line w80"></div>
                  <div class="mock-line w60"></div>
                  <div class="mock-line w90"></div>
                  <div class="mock-line w45"></div>
                </div>
                <div class="mock-tags">
                  <span class="mock-tag"></span>
                  <span class="mock-tag"></span>
                  <span class="mock-tag"></span>
                </div>
              </div>
              <div class="mock-card">
                <div class="mock-card-title"></div>
                <div class="mock-card-body">
                  <div class="mock-line w70"></div>
                  <div class="mock-line w85"></div>
                  <div class="mock-line w50"></div>
                </div>
                <div class="mock-tags">
                  <span class="mock-tag"></span>
                  <span class="mock-tag"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--gradient-hero);
    position: relative;
    overflow: hidden;
    padding-bottom: 80px;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,109,97,0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(120,100,255,0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .nav {
    padding: 20px 32px;
    position: relative;
    z-index: 10;
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1.25rem;
  }

  .logo-icon {
    font-size: 1.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    font-family: var(--font);
  }

  .btn-sm {
    padding: 8px 18px;
    font-size: 0.85rem;
    background: var(--text);
    color: white;
    border-radius: 8px;
  }

  .btn-sm:hover {
    background: #333;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
    box-shadow: 0 2px 12px rgba(255,109,97,0.3), 0 1px 3px rgba(255,109,97,0.2);
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    box-shadow: 0 4px 20px rgba(255,109,97,0.4), 0 2px 6px rgba(255,109,97,0.3);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: var(--bg-card);
    color: var(--text);
    border: 1.5px solid var(--border);
    box-shadow: var(--shadow-sm);
  }

  .btn-secondary:hover {
    border-color: #d0d0d8;
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  .hero-content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 60px 32px 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(255,109,97,0.08);
    border: 1px solid rgba(255,109,97,0.15);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-dark);
    margin-bottom: 24px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  h1 {
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent) 0%, #C96DD8 50%, #7B68EE 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--text-secondary);
    max-width: 480px;
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-tools {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .tools-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }

  .tools-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tool-tag {
    padding: 4px 12px;
    background: rgba(255,255,255,0.7);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  /* App screenshot mockup */
  .hero-screenshot {
    perspective: 1200px;
  }

  .screenshot-window {
    background: var(--bg-card);
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(0,0,0,0.02);
    overflow: hidden;
    transform: rotateY(-4deg) rotateX(2deg);
    transition: transform 0.4s ease;
    animation: float 6s ease-in-out infinite;
  }

  .screenshot-window:hover {
    transform: rotateY(-1deg) rotateX(1deg);
  }

  .window-chrome {
    display: flex;
    gap: 6px;
    padding: 12px 16px;
    background: #F7F7FA;
    border-bottom: 1px solid var(--border);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background: #FF5F57; }
  .dot.yellow { background: #FFBD2E; }
  .dot.green { background: #28CA41; }

  .screenshot-body {
    display: flex;
    height: 340px;
  }

  .mock-sidebar {
    width: 180px;
    background: #F7F7FA;
    border-right: 1px solid var(--border);
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mock-sidebar-header {
    height: 20px;
    width: 60%;
    background: #E0E0E8;
    border-radius: 4px;
    margin-bottom: 8px;
  }

  .mock-item {
    height: 28px;
    background: #EDEDF2;
    border-radius: 6px;
  }

  .mock-item.active {
    background: var(--accent);
    opacity: 0.7;
  }

  .mock-section-label {
    height: 12px;
    width: 50%;
    background: #D8D8E0;
    border-radius: 3px;
    margin-top: 12px;
    margin-bottom: 4px;
  }

  .mock-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .mock-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
  }

  .mock-search {
    height: 28px;
    width: 180px;
    background: #F2F2F6;
    border-radius: 6px;
  }

  .mock-actions {
    display: flex;
    gap: 8px;
  }

  .mock-action-btn {
    width: 28px;
    height: 28px;
    background: #F2F2F6;
    border-radius: 6px;
  }

  .mock-content {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .mock-card {
    background: #FAFAFC;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px;
  }

  .mock-card-title {
    height: 14px;
    width: 40%;
    background: #D0D0D8;
    border-radius: 4px;
    margin-bottom: 10px;
  }

  .mock-card-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 12px;
  }

  .mock-line {
    height: 8px;
    background: #EBEBF0;
    border-radius: 3px;
  }

  .w80 { width: 80%; }
  .w70 { width: 70%; }
  .w60 { width: 60%; }
  .w90 { width: 90%; }
  .w85 { width: 85%; }
  .w50 { width: 50%; }
  .w45 { width: 45%; }

  .mock-tags {
    display: flex;
    gap: 6px;
  }

  .mock-tag {
    height: 20px;
    width: 52px;
    background: rgba(255,109,97,0.1);
    border-radius: 4px;
  }

  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-tools {
      align-items: center;
    }

    .tools-list {
      justify-content: center;
    }

    h1 {
      font-size: 2.5rem;
    }

    .screenshot-window {
      transform: none;
      animation: none;
    }
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 2rem;
    }

    .hero-content {
      padding-top: 32px;
    }

    .nav-links a:not(.btn) {
      display: none;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }

    .mock-sidebar {
      display: none;
    }
  }
</style>
