---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: 'Multi-tool support',
    description: 'Claude Code, Cursor, Codex, Windsurf, Copilot, Aider, Amp — all your agent skills in one place.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
    title: 'Built-in editor',
    description: 'Edit your skills directly. Syntax highlighting, live preview, and instant save back to the source file.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`,
    title: 'Tags & collections',
    description: 'Organize skills with tags and smart collections. Find exactly what you need in seconds.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: 'Real-time file watching',
    description: 'Changes to skill files on disk are picked up instantly. Edit in your terminal, see it in Chops.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
    title: 'Full-text search',
    description: 'Search across all your skills instantly. Filter by tool, tag, or content to find the right skill fast.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
    title: 'Create new skills',
    description: 'Start from scratch or duplicate an existing skill. Write once, use everywhere across all your tools.',
  },
];
---

<section class="features" id="features">
  <div class="features-inner">
    <div class="features-header fade-up">
      <h2>Everything you need to<br /><span class="gradient-text">wrangle your agent skills.</span></h2>
      <p class="features-subtitle">No more scattered markdown files. No more forgetting which tool has which skill. Chops gives you a single, delightful interface for all of it.</p>
    </div>

    <div class="features-grid">
      {features.map((feature, i) => (
        <div class={`feature-card fade-up fade-up-delay-${(i % 4) + 1}`}>
          <div class="feature-icon" set:html={feature.icon} />
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 100px 32px;
    background: var(--bg);
    position: relative;
  }

  .features-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .features-header h2 {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent) 0%, #C96DD8 50%, #7B68EE 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .features-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    transition: all 0.25s ease;
  }

  .feature-card:hover {
    border-color: rgba(255,109,97,0.25);
    box-shadow: var(--shadow-md), 0 0 0 1px rgba(255,109,97,0.05);
    transform: translateY(-4px);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(255,109,97,0.1) 0%, rgba(123,104,238,0.1) 100%);
    border-radius: 12px;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .feature-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .feature-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .features-header h2 {
      font-size: 1.8rem;
    }

    .features {
      padding: 64px 20px;
    }
  }
</style>
